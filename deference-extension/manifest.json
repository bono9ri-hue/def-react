{
  "manifest_version": 3,
  "name": "Deference Collector",
  "version": "1.0.0",
  "description": "Deference 미디어 수집 도구",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://deference.work/*",
    "https://www.deference.work/*",
    "https://def-api.deference.workers.dev/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ]
    }
  ]
}
