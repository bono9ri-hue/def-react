{
  "manifest_version": 3,
  "name": "Deference Design Archive",
  "version": "1.9",
  "description": "디자인 레퍼런스 고속 수집 도구",
  "permissions": [
    "activeTab", 
    "scripting", 
    "storage", 
    "contextMenus",
    "downloads",
    "identity"
  ],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "extension/popup.html" },
  "background": { "service_worker": "extension/background.js", "type": "module" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["extension/content.js"],
    "css": ["extension/content.css"] 
  }],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://deference.work/*",
      "https://*.deference.work/*",
      "https://*.vercel.app/*"
    ]
  }
}