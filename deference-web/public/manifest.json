{
  "manifest_version": 3,
  "name": "Deference Collector",
  "version": "1.0",
  "description": "Deference 미디어 수집 도구",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
