{
    "rules": [
        {
            "allowed": {
                "origins": [
                    "http://localhost:3000",
                    "http://localhost:3001",
                    "http://127.0.0.1:3000"
                ],
                "methods": [
                    "GET",
                    "PUT",
                    "POST",
                    "DELETE",
                    "HEAD"
                ],
                "headers": [
                    "*"
                ]
            },
            "exposeHeaders": [],
            "maxAgeSeconds": 3600
        }
    ]
}